# --- Build stage ---
    FROM golang:1.22-alpine AS builder

    WORKDIR /app
    
    COPY go.mod go.sum ./
    RUN go mod download
    
    COPY . .
    RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /bin/club-backend ./cmd/api/main.go
    
    # --- Runtime stage ---
    FROM alpine:3.19
    
    RUN apk --no-cache add ca-certificates tzdata
    
    WORKDIR /app
    COPY --from=builder /bin/club-backend .
    COPY config.yaml .
    
    EXPOSE 8080
    ENTRYPOINT ["./club-backend"]